        </Combinator>
      </Expression>
      <Expression xsi:type="GroupWorkflow">
        <Name>Camera Logic</Name>
        <Workflow>
          <Nodes>
            <Expression xsi:type="WorkflowInput">
              <Name>Source1</Name>
            </Expression>
            <Expression xsi:type="GroupWorkflow">
              <Name>Computer Timestamp</Name>
              <Description>Timestamps each behavioral camera frame using the computer's clock.</Description>
              <Workflow>
                <Nodes>
                  <Expression xsi:type="WorkflowInput">
                    <Name>Source1</Name>
                  </Expression>
                  <Expression xsi:type="Combinator">
                    <Combinator xsi:type="rx:Timestamp" />
                  </Expression>
                  <Expression xsi:type="MemberSelector">
                    <Selector>Value</Selector>
                  </Expression>
                  <Expression xsi:type="MemberSelector">
                    <Selector>Timestamp.TimeOfDay.TotalMilliseconds</Selector>
                  </Expression>
                  <Expression xsi:type="Combinator">
                    <Combinator xsi:type="rx:Zip" />
                  </Expression>
                  <Expression xsi:type="WorkflowOutput" />
                </Nodes>
                <Edges>
                  <Edge From="0" To="1" Label="Source1" />
                  <Edge From="1" To="2" Label="Source1" />
                  <Edge From="1" To="3" Label="Source1" />
                  <Edge From="2" To="4" Label="Source1" />
                  <Edge From="3" To="4" Label="Source2" />
                  <Edge From="4" To="5" Label="Source1" />
                </Edges>
              </Workflow>
            </Expression>
            <Expression xsi:type="SubscribeSubject">
              <Name>StartDataAcqTrig</Name>
            </Expression>
            <Expression xsi:type="ExternalizedMapping">
              <Property Name="Value" DisplayName="Behavioral Camera ON Time (sec)" />
            </Expression>
            <Expression xsi:type="Combinator">
              <Combinator xsi:type="DoubleProperty">
                <Value>5</Value>
              </Combinator>
            </Expression>
            <Expression xsi:type="Combinator">
              <Combinator xsi:type="rx:CombineLatest" />
            </Expression>
            <Expression xsi:type="Combinator">
              <Combinator xsi:type="rx:WithLatestFrom" />
            </Expression>
            <Expression xsi:type="scr:ExpressionTransform">
              <scr:Expression>new(
Item1.Item2 as CompTime,
Item2.Item1 as TrigState,
Item2.Item2 as Duration)</scr:Expression>
            </Expression>
            <Expression xsi:type="ipy:PythonTransform">
              <ipy:Script>prevTrigState = None

startTime = -1

@returns(bool)
def process(value):
  global prevTrigState, startTime

  currentTime = value.CompTime
  currentTrigState = value.TrigState
  duration = value.Duration * 1000.0
  
  if prevTrigState == None or (not prevTrigState and currentTrigState):
    startTime = currentTime
  
  prevTrigState = currentTrigState
  dt = currentTime - startTime
  
  # Account for date change
  if dt &lt; 0:
    dt = dt + (1000.0 * 3600.0 * 24.0)
  
  return dt &lt; duration</ipy:Script>
            </Expression>
            <Expression xsi:type="Combinator">
              <Combinator xsi:type="rx:Zip" />
            </Expression>
            <Expression xsi:type="WorkflowOutput" />
            <Expression xsi:type="Combinator">
              <Combinator xsi:type="rx:DistinctUntilChanged" />
            </Expression>
            <Expression xsi:type="rx:Condition">
              <Name>IsCameraTurnedOFF</Name>
              <Workflow>
                <Nodes>
